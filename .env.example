APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# URL base do frontend (SPA). Usada no link de redefinição de senha no e-mail.
# Ex.: http://localhost:4200 ou https://app.seudominio.com (sem barra final)
# FRONTEND_URL=

# Landing page (opcional). Copy conforme docs/SPEC_CONCORRENCIA_ASSINATURA_DIGITAL.md
# LANDING_HEADLINE=Consentimentos, anamneses e documentos clínicos com assinatura eletrônica e protocolo.
# LANDING_SUBHEADLINE=Organize a documentação da sua clínica, reduza papelada e tenha trilha de evidências em um fluxo simples para equipe e pacientes.

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# Em produção com Docker/Easy Panel: single,stderr = logs no painel + arquivo (Log Viewer)
LOG_STACK=single,stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Log Viewer (rota /log-viewer): apenas SuperAdmin. Desativar: LOG_VIEWER_ENABLED=false
LOG_VIEWER_ENABLED=true

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@zionmed.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# Resend (https://resend.com). Use MAIL_MAILER=log em desenvolvimento.
RESEND_API_KEY=re_BZGxVp44_3n76owC4fWR35rhinKp1nNTh

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ASAAS (Sandbox: https://sandbox.asaas.com/api/v3)
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_SECRET=
ASAAS_TRIAL_DAYS=14
ASAAS_GRACE_DAYS=7
ASAAS_BLOCK_MODE=soft
ASAAS_PRODUCT_NAME=ZionMed

# n8n webhook para envio de confirmações/avisos por WhatsApp (opcional)
N8N_WHATSAPP_WEBHOOK_URL=


# MinIO (S3-compatível, ex.: Easy Panel). Endpoint = URL da API (porta 9001), não a do Console.
# Nunca commite credenciais reais. Use variáveis de ambiente no servidor.
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_REGION=us-east-1

# Buckets (criar no Console MinIO)
MINIO_SUBMISSIONS_BUCKET=zionmed-submissions
MINIO_ATTACHMENTS_BUCKET=zionmed-attachments
MINIO_ASSETS_BUCKET=zionmed-assets
MINIO_INVOICES_BUCKET=zionmed-invoices