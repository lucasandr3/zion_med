APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# Em produção com Docker/Easy Panel: single,stderr = logs no painel + arquivo (Log Viewer)
LOG_STACK=single,stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Log Viewer (rota /log-viewer): apenas SuperAdmin. Desativar: LOG_VIEWER_ENABLED=false
LOG_VIEWER_ENABLED=true

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ASAAS (Sandbox: https://sandbox.asaas.com/api/v3)
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_SECRET=
ASAAS_TRIAL_DAYS=14
ASAAS_GRACE_DAYS=7
ASAAS_BLOCK_MODE=soft
ASAAS_PRODUCT_NAME=ZionMed

# n8n webhook para envio de confirmações/avisos por WhatsApp (opcional)
N8N_WHATSAPP_WEBHOOK_URL=


# MinIO (S3-compatível, ex.: Easy Panel). Endpoint = URL da API (porta 9001), não a do Console.
MINIO_ENDPOINT="https://utilitarios-minio.jbhyv4.easypanel.host"
MINIO_ACCESS_KEY=zionsuite
MINIO_SECRET_KEY="pkE7xYWWM8q4Zu"
MINIO_REGION=us-east-1

# Buckets (criar no Console MinIO: zionmed-submissions, zionmed-attachments, zionmed-assets, zionmed-invoices)
# MINIO_SUBMISSIONS_BUCKET=zionmed-submissions
# MINIO_ATTACHMENTS_BUCKET=zionmed-attachments
# MINIO_ASSETS_BUCKET=zionmed-assets
# MINIO_INVOICES_BUCKET=zionmed-invoices

MINIO_SUBMISSIONS_BUCKET=zionmed-submissions-dev
MINIO_ATTACHMENTS_BUCKET=zionmed-attachments-dev
MINIO_ASSETS_BUCKET=zionmed-assets-dev
MINIO_INVOICES_BUCKET=zionmed-invoices-dev